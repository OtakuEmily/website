---
import { Forgejo } from "simple-icons-astro";
---

<div
  class="navbar sticky top-0 z-50 border-b border-base-300 bg-base-100/80 px-4 backdrop-blur"
>
  <div class="navbar-start">
    <a class="btn btn-ghost text-xl" href="/" aria-label="Go to homepage">
      <span class="font-bold tracking-tight">Emily</span>
    </a>
  </div>
  <div class="navbar-end">
    <a
      href="https://codeberg.org/otakuemily"
      class="btn btn-ghost btn-circle"
      aria-label="Codeberg profile"
    >
      <Forgejo class="h-5 w-5" />
    </a>
  </div>
</div>
