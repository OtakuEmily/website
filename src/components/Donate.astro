---
import { Bitcoin, Monero } from "simple-icons-astro";

const shortenWallet = (wallet: string) =>
  `${wallet.slice(0, 12)}…${wallet.slice(-12)}`;

const donations = [
  {
    icon: Monero,
    label: "Monero (recommended)",
    wallet:
      "85C2jERwZaBEygKvLfFce27KkrDrb4RhFhGvWbSYrAGJJwKhhcDdXzL7LURNs6vM54SS6gpwEmdQe961mH5Fb4r1BQXUi8b",
  },
  {
    icon: Bitcoin,
    label: "Bitcoin",
    wallet: "bc1q7sa6zgqhkafhc5ccw5whxmfh38rhu994n8f7rc6lalspytz7zgqst3745y",
  },
] as const;
---

<!-- TODO (Emily): Add some type of protection against duplicate Donate.astro scripts OR add a UUID-based instance lock -->
<div class="card border border-base-300 bg-base-100 shadow-sm">
  <div class="card-body gap-4 p-5">
    <div class="flex items-center justify-between gap-3">
      <h2
        class="card-title text-sm font-semibold uppercase tracking-[0.3em] text-base-content/60"
      >
        Donate
      </h2>
    </div>

    <details
      class="collapse collapse-arrow border border-base-300 bg-base-200/60"
    >
      <summary
        class="collapse-title min-h-0 px-4 py-3 text-sm font-semibold text-base-content/80"
      >
        Notice
      </summary>
      <div
        class="collapse-content px-4 pb-4 pt-0 text-sm leading-6 text-base-content/80"
      >
        Donations are considered gifts, gifting me money or crypto does NOT mean
        I'll prioritise an issue or continue to support a project, donations are
        purely just a way to chip in to help me continue doing the things I
        love, donate at your own risk! &lt;3
      </div>
    </details>

    <ul class="space-y-2" aria-label="Donation wallets">
      {
        donations.map(({ icon: Icon, label, wallet }) => (
          <li>
            <button
              type="button"
              class="group flex w-full min-w-0 items-center justify-between gap-3 rounded-box border border-base-300 bg-base-200/60 px-4 py-3 text-left transition-colors hover:bg-base-200/80"
              data-copy-wallet={wallet}
              data-wallet-label={label}
              aria-label={`Copy ${label} wallet address`}
            >
              <div class="flex min-w-0 flex-1 items-center gap-3">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-box bg-base-100 text-base-content/80">
                  {Icon ? <Icon class="h-4 w-4" /> : null}
                </span>
                <div class="min-w-0">
                  <p class="truncate font-medium text-base-content">{label}</p>
                  <p class="truncate font-mono text-xs text-base-content/70">
                    {shortenWallet(wallet)}
                  </p>
                </div>
              </div>
              <span class="badge badge-primary badge-soft shrink-0 justify-center transition-opacity group-hover:opacity-90">
                Copy
              </span>
            </button>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<script is:inline>
  const walletButtons = document.querySelectorAll("[data-copy-wallet]");

  walletButtons.forEach((walletButton) => {
    walletButton.addEventListener("click", async () => {
      const wallet = walletButton.getAttribute("data-copy-wallet");
      if (!wallet) return;

      try {
        await navigator.clipboard.writeText(wallet);

        const copyBadge = walletButton.querySelector(".badge");
        if (copyBadge) {
          copyBadge.textContent = "Copied";
          window.setTimeout(() => {
            copyBadge.textContent = "Copy";
          }, 1500);
        }
      } catch {}
    });
  });
</script>
